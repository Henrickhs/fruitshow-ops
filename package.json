{
  "name": "fruitshow-ops",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "prisma:generate": "npm --workspace api run prisma:generate",
    "prisma:migrate": "npm --workspace api run prisma:migrate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
